{
  "mcpServers": {
    "buyme": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/../local-server/server.mjs"],
      "env": { "BUYME_TOKEN": "${BUYME_TOKEN:-}" }
    },
    "buyme-cloud": {
      "type": "http",
